# GCP
GCP_PROJECT_ID=elec-forecast
GCP_REGION=europe-west9
# Bucket name must be globally unique — use project number as suffix
# Find your project number: gcloud projects describe elec-forecast --format="value(projectNumber)"
GCS_BUCKET=elec-forecast-<project-number>

# BigQuery datasets (no need to change)
BQ_DATASET_RAW=elec_raw
BQ_DATASET_FEATURES=elec_features
BQ_DATASET_ML=elec_ml

# MLflow
# Local dev: http://localhost:5000
# Production: Cloud Run service URL (fill in after first deploy)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=elec-forecast

# Job selector (for Docker entrypoint)
# JOB_MODULE=ingest|features|train|score
JOB_MODULE=ingest
